COOLIFY_API_BASE_URL=https://coolify.example.com/api/v1
COOLIFY_API_TOKEN=your-coolify-api-token
COOLIFY_TIMEOUT_MS=30000
COOLIFY_USER_AGENT=coolify-mcp-server/0.1.0

# Optional indexed profiles. Use server_id=dev or server_id=prod in MCP tool calls.
COOLIFY_1_ID=dev
COOLIFY_1_API_BASE_URL=https://coolify-dev.example.com/api/v1
COOLIFY_1_API_TOKEN=your-dev-coolify-api-token

COOLIFY_2_ID=prod
COOLIFY_2_API_BASE_URL=https://coolify-prod.example.com/api/v1
COOLIFY_2_API_TOKEN=your-prod-coolify-api-token

# Optional named profile style also works. This creates server_id=prod.
COOLIFY_PROD_API_BASE_URL=https://coolify-prod.example.com/api/v1
COOLIFY_PROD_API_TOKEN=your-prod-coolify-api-token

# Optional: allow non-GET/HEAD calls through coolify_api_request.
COOLIFY_ALLOW_RAW_WRITE=false
